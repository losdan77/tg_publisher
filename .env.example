APP_ENV=local
LOG_LEVEL=INFO

DOMAIN=tg.memeinternet.site
TELEGRAM_API_PROXY_DOMAIN=tg-api-test.memeinternet.site
PUBLIC_BASE_URL=https://tg.memeinternet.site
CERTBOT_EMAIL=admin@memeinternet.site
CERTBOT_STAGING=false

NGINX_BASIC_AUTH_USER=admin
NGINX_BASIC_AUTH_PASSWORD=change-this-web-password

APP_UID=1000
APP_GID=1000

OPENAI_API_KEY=sk-your-openai-key
OPENAI_DEFAULT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_TIMEOUT_SECONDS=60
IMAGE_TIMEOUT_SECONDS=120
PEXELS_API_KEY=

TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=change-this-url-secret
TELEGRAM_WEBHOOK_SECRET_TOKEN=change-this-header-secret

ADMIN_API_TOKEN=change-this-admin-api-token
ADMIN_TELEGRAM_USER_IDS=123456789

CHANNELS_CONFIG_PATH=config/channels.yaml
HISTORY_DB_PATH=data/history/posts.sqlite3
ENABLE_SCHEDULER=true
DRY_RUN=false
AUTO_SET_TELEGRAM_WEBHOOK=false
